{
  "expo": {
    "name": "rn-homepage-renderer",
    "slug": "rn-homepage-renderer",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}
